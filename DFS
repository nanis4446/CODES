#include <stdio.h>
int g[10][10],visited[10],n;

void dfs(int i){
    printf("%d ",i);
    visited[i]=1;

    for(int j=0;j<n;j++){
        if(g[i][j] && !visited[j])
            dfs(j);
    }
}

int main(){
    scanf("%d",&n);

    for(int i=0;i<n;i++)
        for(int j=0;j<n;j++)
            scanf("%d",&g[i][j]);

    dfs(0);
}
