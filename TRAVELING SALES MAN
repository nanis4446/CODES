#include <stdio.h>
int n,a[10][10],visited[10],min=999;

void tsp(int city,int count,int cost){
    if(count==n && a[city][0]){
        if(cost+a[city][0]<min)
            min=cost+a[city][0];
        return;
    }

    for(int i=0;i<n;i++){
        if(!visited[i] && a[city][i]){
            visited[i]=1;
            tsp(i,count+1,cost+a[city][i]);
            visited[i]=0;
        }
    }
}

int main(){
    scanf("%d",&n);
    for(int i=0;i<n;i++)
        for(int j=0;j<n;j++)
            scanf("%d",&a[i][j]);

    visited[0]=1;
    tsp(0,1,0);

    printf("%d",min);
}
