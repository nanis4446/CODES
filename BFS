#include <stdio.h>
int main(){
    int g[10][10],visited[10]={0},queue[10];
    int n,i,j,front=0,rear=0;

    scanf("%d",&n);

    for(i=0;i<n;i++)
        for(j=0;j<n;j++)
            scanf("%d",&g[i][j]);

    queue[rear++]=0;
    visited[0]=1;

    while(front<rear){
        i=queue[front++];
        printf("%d ",i);

        for(j=0;j<n;j++){
            if(g[i][j] && !visited[j]){
                queue[rear++]=j;
                visited[j]=1;
            }
        }
    }
}
