#include <stdio.h>
int main(){
    int n,i,j,c[10][10],cost[10];

    scanf("%d",&n);
    for(i=0;i<n;i++)
        for(j=0;j<n;j++)
            scanf("%d",&c[i][j]);

    cost[n-1]=0;

    for(i=n-2;i>=0;i--){
        cost[i]=999;
        for(j=i+1;j<n;j++){
            if(c[i][j]!=0 && c[i][j]+cost[j]<cost[i]){
                cost[i]=c[i][j]+cost[j];
            }
        }
    }

    printf("%d",cost[0]);
}
