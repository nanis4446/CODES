#include <stdio.h>
int main(){
    int n,i,j;
    float w[10],p[10],r[10],cap,temp,total=0;

    scanf("%d",&n);
    for(i=0;i<n;i++){
        scanf("%f%f",&w[i],&p[i]);
        r[i]=p[i]/w[i];
    }

    scanf("%f",&cap);

    for(i=0;i<n;i++){
        for(j=i+1;j<n;j++){
            if(r[i]<r[j]){
                temp=r[i]; r[i]=r[j]; r[j]=temp;
                temp=w[i]; w[i]=w[j]; w[j]=temp;
                temp=p[i]; p[i]=p[j]; p[j]=temp;
            }
        }
    }

    for(i=0;i<n;i++){
        if(w[i]<=cap){
            total+=p[i];
            cap-=w[i];
        }else{
            total+=r[i]*cap;
            break;
        }
    }

    printf("%.2f",total);
}
