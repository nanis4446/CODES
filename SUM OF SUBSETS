#include <stdio.h>

int w[10],x[10],n,target;

void subset(int sum,int k){
    if(k>=n) return;

    x[k]=1;

    if(sum+w[k]==target){
        for(int i=0;i<=k;i++){
            if(x[i]) printf("%d ",w[i]);
        }
        printf("\n");
    } else if(sum+w[k]<target){
        subset(sum+w[k],k+1);
    }

    x[k]=0;
    subset(sum,k+1);
}

int main(){
    scanf("%d",&n);

    for(int i=0;i<n;i++)
        scanf("%d",&w[i]);

    scanf("%d",&target);

    subset(0,0);
}
