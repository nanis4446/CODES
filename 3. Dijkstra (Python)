n=int(input())
g=[list(map(int,input().split())) for _ in range(n)]
start=int(input())

dist=[999]*n
visited=[0]*n
dist[start]=0

for _ in range(n):
    m=999
    u=-1
    for i in range(n):
        if not visited[i] and dist[i]<m:
            m=dist[i]
            u=i
    visited[u]=1

    for v in range(n):
        if g[u][v]!=0 and not visited[v]:
            if dist[u]+g[u][v]<dist[v]:
                dist[v]=dist[u]+g[u][v]

print(*dist)
